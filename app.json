{
  "expo": {
    "name": "Bizar Companion",
    "slug": "bizar-companion",
    "version": "1.1.0-beta.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-camera",
      "expo-secure-store"
    ],
    "android": {
      "package": "com.bizar.companion",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "bizar": {
        "minSupportedDashboardVersion": "5.3.0"
      }
    }
  }
}